rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isVerified() && request.auth.token.email == 'aldo14.snt@gmail.com'; 
    }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidProperty(data) {
      return data.keys().hasAll(['title', 'description', 'price', 'address', 'imageUrl', 'type'])
        && data.keys().size() == 6
        && data.title is string && data.title.size() >= 5 && data.title.size() <= 200
        && data.description is string && data.description.size() >= 10 && data.description.size() <= 2000
        && data.price is number && data.price > 0
        && data.address is string && data.address.size() >= 5 && data.address.size() <= 500
        && data.imageUrl is string && data.imageUrl.size() >= 10 && data.imageUrl.size() <= 1000
        && data.type in ['apartment', 'house', 'condo'];
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'status', 'createdAt', 'lastActive'])
        && data.keys().hasOnly(['name', 'email', 'phone', 'propertyId', 'status', 'createdAt', 'lastActive', 'budget', 'locationPreference', 'timeline', 'crmSynced'])
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.email is string && data.email.size() >= 5 && data.email.size() <= 100
        && (data.get('phone', '') == '' || (data.phone is string && data.phone.size() <= 20))
        && (data.get('propertyId', null) == null || (data.propertyId is string && isValidId(data.propertyId)))
        && data.status in ['new', 'contacted', 'interested', 'viewing_scheduled', 'viewing_completed', 'closed']
        && (data.get('budget', '') == '' || data.budget is string)
        && (data.get('locationPreference', '') == '' || data.locationPreference is string)
        && (data.get('timeline', '') == '' || data.timeline is string)
        && (data.get('crmSynced', false) == false || data.crmSynced is bool)
        && data.lastActive == request.time;
    }

    function isValidLeadCreate(data) {
      return isValidLead(data) && data.createdAt == request.time;
    }

    function isValidLeadUpdate(data) {
      return isValidLead(data) && data.createdAt == existing().createdAt;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'sender', 'timestamp'])
        && data.keys().hasOnly(['text', 'sender', 'timestamp', 'type', 'leadId'])
        && data.text is string && data.text.size() > 0 && data.text.size() <= 5000
        && data.sender in ['user', 'agent']
        && data.timestamp == request.time
        && (data.get('type', '') == '' || data.type is string)
        && (data.get('leadId', null) == null || (data.leadId is string && isValidId(data.leadId)));
    }

    function isValidViewing(data) {
      return data.keys().hasAll(['leadId', 'propertyId', 'dateTime', 'status', 'createdAt'])
        && data.keys().size() == 5
        && isValidId(data.leadId)
        && isValidId(data.propertyId)
        && data.dateTime is number && data.dateTime > 0
        && data.status in ['pending', 'confirmed', 'cancelled']
        && data.createdAt == request.time;
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['leadId', 'text', 'dateTime', 'completed', 'createdAt'])
        && data.keys().size() == 5
        && isValidId(data.leadId)
        && data.text is string && data.text.size() > 0 && data.text.size() <= 1000
        && data.dateTime is number && data.dateTime > 0
        && data.completed is bool;
    }

    function isValidReminderCreate(data) {
      return isValidReminder(data) && data.createdAt == request.time;
    }

    function isValidReminderUpdate(data) {
      return isValidReminder(data) && data.createdAt == existing().createdAt;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['welcomeEmailSubject', 'welcomeEmailBody'])
        && data.keys().size() == 2
        && data.welcomeEmailSubject is string && data.welcomeEmailSubject.size() <= 200
        && data.welcomeEmailBody is string && data.welcomeEmailBody.size() <= 5000;
    }

    // 1. Properties
    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProperty(incoming()) && isValidId(propertyId);
      allow update: if isAdmin() && isValidProperty(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'address', 'imageUrl', 'type'])
      );
      allow delete: if isAdmin();
    }

    // 2. Leads
    match /leads/{leadId} {
      // Public can create a lead
      allow create: if isValidLeadCreate(incoming()) && isValidId(leadId);
      // Admin can manage everything
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow update: if (isAdmin() && isValidLeadUpdate(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'lastActive', 'name', 'email', 'phone', 'propertyId', 'budget', 'locationPreference', 'timeline', 'crmSynced'])
      )) || (
        // Public can update their own lead's qualification info during chat
        isValidLeadUpdate(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['budget', 'locationPreference', 'timeline', 'lastActive', 'crmSynced'])
      );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        // Public can send message to a lead
        allow create: if isValidMessage(incoming()) && isValidId(messageId);
        allow read: if isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // 3. Viewings
    match /viewings/{viewingId} {
      // Public create viewing (request)
      allow create: if isValidViewing(incoming()) && isValidId(viewingId) 
        && exists(/databases/$(database)/documents/leads/$(incoming().leadId))
        && exists(/databases/$(database)/documents/properties/$(incoming().propertyId));
      allow read: if isAdmin();
      allow update: if isAdmin() && isValidViewing(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'dateTime'])
      );
      allow delete: if isAdmin();
    }

    // 4. Reminders
    match /reminders/{reminderId} {
      // Public create reminder (AI bot triggered from client)
      allow create: if isValidReminderCreate(incoming()) && isValidId(reminderId);
      allow read: if isAdmin();
      allow update: if isAdmin() && isValidReminderUpdate(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'text', 'dateTime'])
      );
      allow delete: if isAdmin();
    }

    // 5. Settings
    match /settings/{settingId} {
      allow read: if true; // Public bot needs to read settings
      allow write: if isAdmin() && isValidSettings(incoming()) && isValidId(settingId);
    }
  }
}

